# OpenAI (existing)
OPENAI_API_KEY=

# ── Supabase Auth (https://supabase.com/dashboard) ───────────────────────────
# Project URL — use the base URL only (NOT /rest/v1)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Browser-safe key (Dashboard → Connect → Next.js shows sb_publishable_…)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy JWT anon key — optional if publishable key is set
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT Secret (legacy HS256 fallback): Dashboard → Project Settings → API → JWT Secret
# User sessions on newer projects use ES256 + JWKS; the server verifies those automatically.
SUPABASE_JWT_SECRET=your-jwt-secret

# Public URL (production) — used for email confirmation redirects after sign-up
APP_PUBLIC_URL=https://verbum-zu1l.onrender.com

# Comma-separated superadmin emails — full app access + approve memberships, songs, and priests
SUPERADMIN_EMAILS=you@example.com

# Invite-only signup (default on in production / Render). Set 0 for open sign-up in local dev.
# INVITE_ONLY_SIGNUP=1
# Optional contact shown on landing/sign-in when users need access (defaults to first SUPERADMIN_EMAILS)
# INVITE_CONTACT_EMAIL=admin@yourparish.org

# Landing access-request form (POST /api/access-request) — emails admin + requester.
# Defaults to divinogabriel76@gmail.com if ACCESS_REQUEST_TO / INVITE_CONTACT_EMAIL unset.
# ACCESS_REQUEST_TO=divinogabriel76@gmail.com
#
# Email provider (pick one — Brevo recommended):
# BREVO_API_KEY=xkeysib-...
# BREVO_FROM=LiturgyFlow <noreply@yourdomain.com>
# Or Resend:
# RESEND_API_KEY=
# RESEND_FROM=LiturgyFlow <onboarding@resend.dev>
# Or SMTP (Brevo SMTP: smtp-relay.brevo.com:587):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login@email.com
# SMTP_PASSWORD=your-smtp-key
# SMTP_FROM=LiturgyFlow <noreply@yourdomain.com>
# EMAIL_FROM=LiturgyFlow <noreply@yourdomain.com>
#
# Weekly reminders (Wed Mass PPTX / Fri choir practice share):
# EMAIL_REMINDERS_ENABLED=1
# CRON_SECRET=long-random-string
# Trigger: POST /api/internal/email-reminders/run  Header: X-Cron-Secret: …
# Or: python scripts/run_email_reminders.py --kind mass_pptx|practice_share|auto

# AI image generation quota (OpenAI / Gemini poster art)
IMAGE_GENERATION_DAILY_LIMIT=1

# ── Rate limiting & request safety ───────────────────────────────────────────
# Set RATE_LIMIT_ENABLED=0 to disable (not recommended in production).
# Limits are "max requests per window(seconds)" keyed by user/IP.
RATE_LIMIT_ENABLED=1
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_EXPENSIVE_MAX=20
RATE_LIMIT_EXPENSIVE_WINDOW=60
RATE_LIMIT_API_MAX=120
RATE_LIMIT_API_WINDOW=60
RATE_LIMIT_DEFAULT_MAX=300
RATE_LIMIT_DEFAULT_WINDOW=60
# Reject request bodies larger than this many bytes (default 12 MB).
MAX_REQUEST_BODY_BYTES=12582912

# ── Setup checklist ───────────────────────────────────────────────────────────
# 1. Enable Email provider: Authentication → Providers → Email
# 2. Run SQL migrations in order:
#    - supabase/migrations/202506100001_profiles.sql
#    - supabase/migrations/202506100002_rls_hardening.sql
#    - supabase/migrations/202506100003_church_on_signup.sql
#    - supabase/migrations/202506100004_security_hardening.sql
#    - supabase/migrations/202506100005_backfill_church_profiles.sql
#    - supabase/migrations/202506100006_parish_membership.sql
#    - supabase/migrations/202506100007_logo_lock.sql
#    - supabase/migrations/202506100008_role_security.sql
#    - supabase/migrations/202506100009_security_rpc_hardening.sql
#    - supabase/migrations/202506100010_drop_clerk_user_id.sql
#    - supabase/migrations/202506100011_membership_lock_guards.sql
# 3. Set SUPERADMIN_EMAILS in .env — bootstraps profiles.role=superadmin on server start
# 4. Restart server and visit /sign-up to create an account
# 4. NOTE: in-process rate limiting assumes a single app instance. For multiple
#    instances/workers, front the app with a shared limiter (Cloudflare, or a
#    Redis-backed limiter) so limits are global.
